# ── AWS Credentials ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Option 1: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# LLM_MODEL=gpt-4o

# Option 2: Groq (recommended — fast, free tier)  https://console.groq.com
#LLM_PROVIDER=
#GROQ_API_KEY=
#GROQ_MODEL=llama-3.3-70b-versatile

# Option 3: Ollama (fully local)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Option 4: AWS Bedrock
# LLM_PROVIDER=bedrock
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Option 5: IBM WatsonX  https://dataplatform.cloud.ibm.com
# LLM_PROVIDER=watsonx
# WATSONX_API_KEY=your_ibm_cloud_api_key
# WATSONX_PROJECT_ID=your_watsonx_project_id
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_LLM_MODEL=ibm/granite-3-8b-instruct
# WATSONX_EMBED_MODEL=ibm/slate-125m-english-rtrvr

# ── Embeddings (free — works with any LLM_PROVIDER above) ────────────────────
# Get a free READ token at: https://huggingface.co/settings/tokens
EMBED_PROVIDER=
HUGGINGFACE_API_KEY=
HF_EMBED_MODEL=

# ── Agent Config ──────────────────────────────────────────────────────────────
AGENT_POLL_INTERVAL_SECONDS=60
AGENT_MAX_HEALING_RETRIES=3
AGENT_DRY_RUN=false           # set false when ready to let the agent take real actions

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vector_store
KNOWLEDGE_BASE_PATH=./knowledge_base

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── AWS Resources to monitor (comma-separated, leave blank = auto-discover) ───
MONITOR_EC2_INSTANCE_IDS=
MONITOR_RDS_CLUSTER_IDS=
MONITOR_ECS_CLUSTER_NAMES=
MONITOR_LAMBDA_FUNCTION_NAMES=
MONITOR_ALB_NAMES=
